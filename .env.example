# .env.template for MiniStatus

# Flask config
FLASK_APP=run.py
FLASK_ENV=development

# Security
SECRET_KEY=your-secret-key-here

# Admin auth (password is bcrypt-hashed automatically on first login or via Settings)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password-here

# Polymarket Alerts integration (required for the Polymarket pages)
# Path to polymarket-alerts directory containing alerts_log.csv
# POLYMARKET_DATA_PATH=/home/ubuntu/polymarket-alerts
# Debug candidates CSV filename (must match polymarket-alerts DEBUG_CANDIDATES_CSV; default: debug_candidates.csv)
# POLYMARKET_DEBUG_CSV=debug_candidates.csv
